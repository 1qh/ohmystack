{
  "name": "@a/agent",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun with-env next build --turbo",
    "dev": "PORT=4400 bun with-env next dev --turbo",
    "start": "bun with-env next start",
    "test": "NEXT_PUBLIC_CONVEX_TEST_MODE=true CONVEX_TEST_MODE=true NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:4001 bun with-env playwright test --reporter=dot",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../.env --"
  },
  "dependencies": {
    "@a/be-agent": "workspace:*",
    "@a/ui": "workspace:*",
    "next": "latest"
  },
  "devDependencies": {
    "@a/e2e": "workspace:*"
  }
}
