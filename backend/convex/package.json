{
  "name": "@a/be-convex",
  "private": true,
  "exports": {
    ".": "./convex/_generated/api.js",
    "./ai": "./ai.ts",
    "./chat": "./convex/chat.ts",
    "./lazy": "./lazy.ts",
    "./model": "./convex/_generated/dataModel.d.ts",
    "./server": "./convex/_generated/server.js",
    "./s": "./s.ts"
  },
  "scripts": {
    "build": "tsc",
    "check:schema": "bun ./check-schema.ts",
    "dev": "nb-env convex dev",
    "prod": "nb-env convex deploy",
    "test:integration": "CONVEX_TEST_MODE=true nb-env bun test convex/f.test.ts convex/org-api.test.ts convex/edge.test.ts",
    "typecheck": "bun check:schema && tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "latest",
    "@noboil/convex": "workspace:*",
    "@t3-oss/env-nextjs": "latest",
    "convex": "latest",
    "convex-helpers": "latest",
    "convex-test": "latest",
    "ky": "latest"
  },
  "devDependencies": {
    "@a/e2e": "workspace:*"
  }
}
