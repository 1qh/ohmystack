{
  "expo": {
    "name": "Chat",
    "slug": "mobile-spacetimedb-chat",
    "version": "1.0.0",
    "scheme": "noboil-stdb-chat",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "dev.noboil.mobilestdbchat"
    },
    "android": {
      "package": "dev.noboil.mobilestdbchat"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
