{
  "name": "@noboil/convex",
  "version": "0.0.0",
  "description": "Schema-first, zero-boilerplate fullstack with Convex.",
  "keywords": [
    "convex",
    "crud",
    "zod",
    "react",
    "nextjs",
    "fullstack",
    "forms",
    "file-upload",
    "pagination",
    "multi-tenancy",
    "acl",
    "soft-delete",
    "rate-limiting"
  ],
  "homepage": "https://github.com/1qh/noboil",
  "bugs": "https://github.com/1qh/noboil/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/1qh/noboil.git",
    "directory": "lib/convex"
  },
  "license": "MIT",
  "author": "1qh",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./dist/server/index.mjs"
    },
    "./zod": {
      "types": "./src/zod.ts",
      "import": "./dist/zod.mjs"
    },
    "./retry": {
      "types": "./src/retry.ts",
      "import": "./dist/retry.mjs"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./dist/schema.mjs"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./dist/react/index.mjs"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./dist/components/index.mjs"
    },
    "./eslint": {
      "types": "./src/eslint.ts",
      "import": "./dist/eslint.mjs"
    },
    "./next": {
      "types": "./src/next/index.ts",
      "import": "./dist/next/index.mjs"
    },
    "./test": {
      "types": "./src/server/test.ts",
      "import": "./dist/server/test.mjs"
    },
    "./test/discover": {
      "types": "./src/server/test-discover.ts",
      "import": "./dist/server/test-discover.mjs"
    },
    "./seed": {
      "types": "./src/seed.ts",
      "import": "./dist/seed.mjs"
    }
  },
  "bin": {
    "noboil-convex": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__"
  ],
  "scripts": {
    "build": "tsdown",
    "cleanup-old-versions": "bun script/cleanup-old-versions.ts",
    "prepublishOnly": "bun run build",
    "postpublish": "bun run cleanup-old-versions",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "browser-image-compression": "latest",
    "next-navigation-guard": "latest",
    "react-dropzone": "latest"
  },
  "devDependencies": {
    "@a/shared": "workspace:*",
    "@a/ui": "workspace:*"
  },
  "peerDependencies": {
    "@auth/core": "0.41",
    "@convex-dev/auth": "latest",
    "@stepperize/react": "latest",
    "@tanstack/react-form": "latest",
    "convex": "latest",
    "convex-helpers": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  }
}
