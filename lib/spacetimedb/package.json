    "react-dropzone": "latest"
  },
  "peerDependencies": {
    "@noboil/shared": "*",
    "@stepperize/react": "latest",
    "@tanstack/react-form": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "spacetimedb": "latest",
    "zod": "latest"
  }
}
