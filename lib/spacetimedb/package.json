{
  "name": "@noboil/spacetimedb",
  "version": "0.0.1",
  "description": "Schema-first, zero-boilerplate fullstack with SpacetimeDB.",
  "keywords": [
    "spacetimedb",
    "crud",
    "typesafety",
    "zod",
    "react",
    "nextjs",
    "fullstack",
    "forms",
    "file-upload",
    "pagination",
    "multi-tenancy",
    "acl",
    "soft-delete",
    "rate-limiting"
  ],
  "homepage": "https://github.com/1qh/noboil",
  "bugs": "https://github.com/1qh/noboil/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/1qh/noboil.git",
    "directory": "lib/spacetimedb"
  },
  "license": "MIT",
  "author": "1qh",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./zod": "./src/zod.ts",
    "./retry": "./src/retry.ts",
    "./schema": "./src/schema.ts",
    "./react": "./src/react/index.ts",
    "./components": "./src/components/index.ts",
    "./eslint": "./src/eslint.ts",
    "./next": "./src/next/index.ts",
    "./test": "./src/server/test.ts",
    "./test/discover": "./src/server/test-discover.ts",
    "./seed": "./src/seed.ts"
  },
  "bin": {
    "noboil-stdb": "./src/cli.ts"
  },
  "files": [
    "src",
    "!src/__tests__"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "postpublish": "bunx pm4ai@latest cleanup",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "browser-image-compression": "latest",
