{
  "name": "a",
  "private": true,
  "workspaces": [
    "web/cvx/*",
    "doc",
    "web/stdb/*",
    "lib/*",
    "readonly/*",
    "backend/*"
  ],
  "scripts": {
    "action": "sh up.sh && bun run test",
    "build": "turbo run build --output-logs=errors-only",
    "check": "lintmax check",
    "clean": "sh clean.sh",
    "convex:reset": "docker compose -f convex.yml down -v && bun script/setup-convex.ts",
    "convex:up": "bun script/emit-env.ts && docker compose -f convex.yml up -d --quiet-pull",
    "crawl": "bun script/crawl.ts",
    "dev:all": "bun script/dev.ts",
    "dev:web": "f() { turbo watch dev -F @a/$1 -F @a/$2; }; f",
    "doctor": "bun script/doctor.ts",
    "fix": "lintmax fix && turbo typecheck build --output-logs=errors-only",
    "gha:run-ci-full": "bash -lc 'b=$(git branch --show-current); gh workflow run CI --ref \"$b\" -f force_full=true && gh run list --workflow CI --branch \"$b\" --limit 3'",
    "postinstall": "sherif && bun script/patch-stdb-sdk.ts",
    "prepare": "bunx simple-git-hooks",
    "publish": "bun run --cwd lib/noboil publish",
    "publish:dry": "bun run --cwd lib/noboil publish:dry",
    "setup": "bun script/setup.ts",
    "setup:convex": "bun script/setup-convex.ts",
    "setup:spacetimedb": "bun script/setup-spacetimedb.ts",
    "spacetime:generate": "bun script/stdb-generate.ts",
    "spacetime:health": "bun script/stdb-health.ts",
    "spacetime:publish": "bun script/stdb-publish.ts --delete-data=on-conflict -y",
    "spacetime:reset": "docker compose -f spacetimedb.yml down -v && bun script/setup-spacetimedb.ts",
    "spacetime:up": "bun script/emit-env.ts && docker compose -f spacetimedb.yml up -d --quiet-pull",
    "test": "turbo test --output-logs=errors-only",
    "test:all": "bun script/test-all.ts",
    "test:all:watch": "bash script/watch-test-all.sh",
    "test:web": "bun run test",
    "tsc": "turbo run typecheck --output-logs=errors-only",
    "verify": "bun run tsc && bun run check && bun run build"
  },
  "simple-git-hooks": {
    "pre-commit": "sh up.sh && git add -u"
  },
  "dependencies": {
    "@a/config": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@tailwindcss/typography": "latest",
    "@turbo/gen": "latest",
    "@types/mdx": "latest",
    "@types/node": "latest",
    "axe-core": "latest",
    "babel-plugin-react-compiler": "latest",
    "depcheck": "latest",
    "lintmax": "latest",
    "sherif": "latest",
    "simple-git-hooks": "latest",
    "ts-unused-exports": "latest",
    "tsdown": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.12",
  "trustedDependencies": [
    "esbuild",
    "lintmax",
    "msw",
    "sharp",
    "simple-git-hooks"
  ]
}
