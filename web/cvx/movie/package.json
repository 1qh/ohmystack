{
  "name": "@a/convex-movie",
  "type": "module",
  "scripts": {
    "build": "bun with-env next build --turbo",
    "dev": "PORT=4102 bun with-env next dev --turbo",
    "start": "bun with-env next start",
    "test": "CONVEX_TEST_MODE=true bun with-env playwright test --reporter=dot",
    "test:e2e": "CONVEX_TEST_MODE=true bun --cwd ../../../backend/convex with-env convex dev --once && bun with-env playwright test --reporter=list",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../../.env --"
  },
  "devDependencies": {
    "@a/e2e": "workspace:*"
  }
}
