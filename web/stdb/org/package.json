{
  "name": "@a/stdb-org",
  "type": "module",
  "scripts": {
    "build": "bun with-env next build --turbo",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "PORT=3004 bun with-env next dev --turbo",
    "start": "bun with-env next start",
    "test": "SPACETIMEDB_TEST_MODE=true bun with-env playwright test --reporter=dot",
    "test:e2e": "SPACETIMEDB_TEST_MODE=true bun spacetime:publish && bun with-env playwright test --reporter=list",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../../.env --"
  },
  "dependencies": {
    "@sindresorhus/slugify": "latest"
  },
  "devDependencies": {
    "@a/e2e": "workspace:*",
    "@playwright/test": "latest"
  }
}
